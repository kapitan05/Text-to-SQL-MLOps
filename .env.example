# AWS — used by ml/ (MLflow S3 artifacts) and app/ (S3 + DynamoDB)
AWS_ACCESS_KEY_ID=your_key_here
AWS_SECRET_ACCESS_KEY=your_secret_here
AWS_DEFAULT_REGION=us-east-1

# S3 bucket names
MLFLOW_BUCKET=text2sql-mlflow-artifacts
FAILED_SQL_BUCKET=text2sql-failed-sql
DATASET_BUCKET=text2sql-active-learning

# HuggingFace (required for gated models like Llama-3)
HF_TOKEN=your_hf_token_here

# App (Lambda environment)
MODEL_PATH=/opt/model.gguf
N_CTX=2048
N_THREADS=4
MAX_TOKENS=256

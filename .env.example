# ── AWS credentials
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# ── S3 buckets
MLFLOW_BUCKET=text2sql-mlflow-artifacts       # ml/ training artifacts
FAILED_SQL_BUCKET=text2sql-failed-sql         # app/ failure logs + Evidently reports
MONITORING_BUCKET=text2sql-failed-sql         # Evidently HTML reports (defaults to FAILED_SQL_BUCKET)
DATASET_BUCKET=text2sql-dataset          # Airflow active-learning output

# ── HuggingFace
HF_TOKEN=

# ── App / SageMaker inference runtime
DYNAMODB_TABLE=query_results
SAGEMAKER_ENDPOINT_NAME=text2sql-inference
PUSHGATEWAY_URL=http://localhost:9091         # in prod: monitoring_pushgateway_url tf output
GGUF_PATH=/opt/ml/model/model_q4_k_m.gguf     # sagemaker/ container model path
MODEL_N_CTX=512
MODEL_N_THREADS=4
METRICS_PUSH_INTERVAL=15                       # sagemaker/ metrics push cadence (seconds)

# ── Monitoring / Airflow
# MLflow server is started by ml/vast_setup.sh (training) or the monitoring EC2
# (prod: monitoring_mlflow_url tf output).
MLFLOW_TRACKING_URI=http://localhost:5000
GRAFANA_PASSWORD=admin

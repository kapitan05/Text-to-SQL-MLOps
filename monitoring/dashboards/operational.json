{
  "__inputs": [{"name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus"}],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"},
    {"type": "panel", "id": "timeseries", "name": "Time series", "version": ""},
    {"type": "panel", "id": "stat", "name": "Stat", "version": ""}
  ],
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Request Rate (5m)",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [{"expr": "sum(rate(text2sql_requests_total[5m]))", "legendFormat": "req/s", "refId": "A", "datasource": {"type": "prometheus", "uid": "${datasource}"}}],
      "fieldConfig": {"defaults": {"unit": "reqps", "color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}]}}},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "textMode": "auto"}
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Error Rate (5m)",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [{"expr": "sum(rate(text2sql_requests_total{status=\"failure\"}[5m])) / sum(rate(text2sql_requests_total[5m])) * 100 or vector(0)", "legendFormat": "error %", "refId": "A", "datasource": {"type": "prometheus", "uid": "${datasource}"}}],
      "fieldConfig": {"defaults": {"unit": "percent", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 5}, {"color": "red", "value": 10}]}}},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"}
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Inference p95 (5m)",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [{"expr": "histogram_quantile(0.95, sum by(le)(rate(text2sql_inference_duration_seconds_bucket[5m])))", "legendFormat": "p95", "refId": "A", "datasource": {"type": "prometheus", "uid": "${datasource}"}}],
      "fieldConfig": {"defaults": {"unit": "s", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 5}, {"color": "red", "value": 10}]}}},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"}
    },
    {
      "id": 4,
      "type": "stat",
      "title": "DynamoDB Write Success Rate",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [{"expr": "sum(rate(text2sql_dynamo_writes_total{status=\"success\"}[5m])) / sum(rate(text2sql_dynamo_writes_total[5m])) * 100 or vector(100)", "legendFormat": "%", "refId": "A", "datasource": {"type": "prometheus", "uid": "${datasource}"}}],
      "fieldConfig": {"defaults": {"unit": "percent", "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 90}, {"color": "green", "value": 99}]}}},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"}
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Request Rate by Status",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [{"expr": "sum by(status)(rate(text2sql_requests_total[5m]))", "legendFormat": "{{status}}", "refId": "A", "datasource": {"type": "prometheus", "uid": "${datasource}"}}],
      "fieldConfig": {"defaults": {"unit": "reqps", "custom": {"lineWidth": 2, "fillOpacity": 10}}},
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "table", "placement": "bottom"}}
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "End-to-End Latency Percentiles",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {"expr": "histogram_quantile(0.50, sum by(le)(rate(text2sql_request_duration_seconds_bucket[5m])))", "legendFormat": "p50", "refId": "A", "datasource": {"type": "prometheus", "uid": "${datasource}"}},
        {"expr": "histogram_quantile(0.95, sum by(le)(rate(text2sql_request_duration_seconds_bucket[5m])))", "legendFormat": "p95", "refId": "B", "datasource": {"type": "prometheus", "uid": "${datasource}"}},
        {"expr": "histogram_quantile(0.99, sum by(le)(rate(text2sql_request_duration_seconds_bucket[5m])))", "legendFormat": "p99", "refId": "C", "datasource": {"type": "prometheus", "uid": "${datasource}"}}
      ],
      "fieldConfig": {"defaults": {"unit": "s", "custom": {"lineWidth": 2}}},
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "table", "placement": "bottom"}}
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "SageMaker Inference Latency p95",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {"expr": "histogram_quantile(0.95, sum by(le)(rate(text2sql_inference_duration_seconds_bucket[5m])))", "legendFormat": "lambda→sagemaker p95", "refId": "A", "datasource": {"type": "prometheus", "uid": "${datasource}"}},
        {"expr": "histogram_quantile(0.95, sum by(le)(rate(flask_http_request_duration_seconds_bucket{path=\"/invocations\"}[5m])))", "legendFormat": "sagemaker server p95", "refId": "B", "datasource": {"type": "prometheus", "uid": "${datasource}"}}
      ],
      "fieldConfig": {"defaults": {"unit": "s", "custom": {"lineWidth": 2}}},
      "options": {"tooltip": {"mode": "multi"}}
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Kinesis Records (valid vs malformed)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [{"expr": "sum by(status)(rate(text2sql_kinesis_records_total[5m]))", "legendFormat": "{{status}}", "refId": "A", "datasource": {"type": "prometheus", "uid": "${datasource}"}}],
      "fieldConfig": {"defaults": {"unit": "cps", "custom": {"lineWidth": 2, "fillOpacity": 5}}},
      "options": {"tooltip": {"mode": "multi"}}
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Inference Retry Attempts",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [{"expr": "sum by(attempt)(rate(text2sql_inference_retries_total[5m]))", "legendFormat": "attempt {{attempt}} failed", "refId": "A", "datasource": {"type": "prometheus", "uid": "${datasource}"}}],
      "fieldConfig": {"defaults": {"unit": "cps", "custom": {"lineWidth": 2}}},
      "options": {"tooltip": {"mode": "multi"}}
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Kinesis Batch Size Distribution",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {"expr": "histogram_quantile(0.50, sum by(le)(rate(text2sql_batch_size_bucket[5m])))", "legendFormat": "p50", "refId": "A", "datasource": {"type": "prometheus", "uid": "${datasource}"}},
        {"expr": "histogram_quantile(0.95, sum by(le)(rate(text2sql_batch_size_bucket[5m])))", "legendFormat": "p95", "refId": "B", "datasource": {"type": "prometheus", "uid": "${datasource}"}}
      ],
      "fieldConfig": {"defaults": {"unit": "short", "custom": {"lineWidth": 2}}},
      "options": {"tooltip": {"mode": "multi"}}
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["text2sql", "operational"],
  "templating": {
    "list": [{"current": {}, "hide": 0, "includeAll": false, "multi": false, "name": "datasource", "options": [], "query": "prometheus", "refresh": 1, "type": "datasource"}]
  },
  "time": {"from": "now-1h", "to": "now"},
  "timezone": "browser",
  "title": "Text2SQL — Operational",
  "uid": "text2sql-ops",
  "version": 1
}

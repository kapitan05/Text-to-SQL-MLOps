{
  "__inputs": [{"name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus"}],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"},
    {"type": "panel", "id": "timeseries", "name": "Time series", "version": ""},
    {"type": "panel", "id": "stat", "name": "Stat", "version": ""}
  ],
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Latency p95 — 1h rolling",
      "description": "Rising trend signals model degradation or infra issues",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {"expr": "histogram_quantile(0.95, sum by(le)(rate(text2sql_request_duration_seconds_bucket[5m])))", "legendFormat": "end-to-end p95", "refId": "A", "datasource": {"type": "prometheus", "uid": "${datasource}"}},
        {"expr": "histogram_quantile(0.95, sum by(le)(rate(text2sql_inference_duration_seconds_bucket[5m])))", "legendFormat": "inference p95", "refId": "B", "datasource": {"type": "prometheus", "uid": "${datasource}"}},
        {"expr": "histogram_quantile(0.95, sum by(le)(rate(flask_http_request_duration_seconds_bucket{path=\"/invocations\"}[5m])))", "legendFormat": "sagemaker server p95", "refId": "C", "datasource": {"type": "prometheus", "uid": "${datasource}"}}
      ],
      "fieldConfig": {"defaults": {"unit": "s", "custom": {"lineWidth": 2, "fillOpacity": 10}}},
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "lastNotNull"]}}
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Error Rate Trend",
      "description": "Sustained increase → retraining signal",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [{"expr": "sum(rate(text2sql_requests_total{status=\"failure\"}[5m])) / sum(rate(text2sql_requests_total[5m])) * 100 or vector(0)", "legendFormat": "error rate %", "refId": "A", "datasource": {"type": "prometheus", "uid": "${datasource}"}}],
      "fieldConfig": {"defaults": {"unit": "percent", "custom": {"lineWidth": 2, "fillOpacity": 20}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 5}, {"color": "red", "value": 10}]}}},
      "options": {"tooltip": {"mode": "single"}}
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Inference Retry Rate",
      "description": "High retry rate → SageMaker endpoint instability",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [{"expr": "sum by(attempt)(rate(text2sql_inference_retries_total[5m]))", "legendFormat": "attempt {{attempt}} failed", "refId": "A", "datasource": {"type": "prometheus", "uid": "${datasource}"}}],
      "fieldConfig": {"defaults": {"unit": "cps", "custom": {"lineWidth": 2}}},
      "options": {"tooltip": {"mode": "multi"}}
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Result Row Distribution",
      "description": "Shift toward 0 rows may indicate SQL correctness regression",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {"expr": "histogram_quantile(0.50, sum by(le)(rate(text2sql_result_rows_bucket[5m])))", "legendFormat": "p50 rows", "refId": "A", "datasource": {"type": "prometheus", "uid": "${datasource}"}},
        {"expr": "histogram_quantile(0.95, sum by(le)(rate(text2sql_result_rows_bucket[5m])))", "legendFormat": "p95 rows", "refId": "B", "datasource": {"type": "prometheus", "uid": "${datasource}"}}
      ],
      "fieldConfig": {"defaults": {"unit": "short", "custom": {"lineWidth": 2}}},
      "options": {"tooltip": {"mode": "multi"}}
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "SageMaker — Flask Request Rate",
      "description": "From prometheus_flask_exporter /metrics on serve.py",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {"expr": "sum by(status)(rate(flask_http_request_total{path=\"/invocations\"}[5m]))", "legendFormat": "{{status}}", "refId": "A", "datasource": {"type": "prometheus", "uid": "${datasource}"}}
      ],
      "fieldConfig": {"defaults": {"unit": "reqps", "custom": {"lineWidth": 2, "fillOpacity": 5}}},
      "options": {"tooltip": {"mode": "multi"}}
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Model Load Time",
      "description": "Set once at SageMaker server startup",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 24},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [{"expr": "text2sql_sagemaker_model_load_seconds", "legendFormat": "load time", "refId": "A", "datasource": {"type": "prometheus", "uid": "${datasource}"}}],
      "fieldConfig": {"defaults": {"unit": "s"}},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "value"}
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["text2sql", "ml-quality"],
  "templating": {
    "list": [{"current": {}, "hide": 0, "includeAll": false, "multi": false, "name": "datasource", "options": [], "query": "prometheus", "refresh": 1, "type": "datasource"}]
  },
  "time": {"from": "now-6h", "to": "now"},
  "timezone": "browser",
  "title": "Text2SQL — ML Quality",
  "uid": "text2sql-ml",
  "version": 1
}
